generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id              String   @id @default(cuid())
  userId          String
  title           String
  shortSummary    String
  detailedSummary String
  keyConcepts     String[]
  transcript      String
  duration        Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tasks      Task[]
  flashcards Flashcard[]
  keyMoments KeyMoment[]

  @@index([userId])
  @@index([userId, createdAt])
}

model Task {
  id        String    @id @default(cuid())
  sessionId String
  session   Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  text      String
  priority  Priority
  dueDate   DateTime?
  done      Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([sessionId])
}

enum Priority {
  High
  Medium
  Low
}

model Flashcard {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  question  String
  answer    String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
}

model KeyMoment {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  timestamp String
  quote     String
  why       String
  createdAt DateTime @default(now())

  @@index([sessionId])
}

model DigestSettings {
  id                  String   @id @default(cuid())
  userId              String   @unique
  weeklyDigestEnabled Boolean  @default(true)
  taskReminders       Boolean  @default(true)
  newFeatureEmails    Boolean  @default(false)
  updatedAt           DateTime @updatedAt
}
